Algoritmo Act2inc2
    Definir numeros, i, mayor, posicionComoEntero Como Entero
    Dimension numeros[8]
    
    Para i = 1 Hasta 8 Con Paso 1 Hacer
        Escribir "Ingrese el número entero ", i, ":"
        Leer numeros[i]
    FinPara
    
    mayor = numeros[1]
    posicion = 1
    
    Para i = 2 Hasta 8 Con Paso 1 Hacer
        Si numeros[i] > mayor Entonces
            mayor = numeros[i]
            posicion = i
        FinSi
    FinPara
    
    Escribir "El número mayor es: ", mayor
    Escribir "Se encuentra en la posición: ", posicion
FinAlgoritmo
